# Supabase Configuration
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service Role Key (for admin APIs - KEEP SECRET, never expose to browser)
# Get this from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Email Service (Resend) - for transactional emails like password resets
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Optional email configuration
# EMAIL_FROM=Titan First Read <noreply@yourdomain.com>
# EMAIL_REPLY_TO=support@yourdomain.com

# App URL (used for email links and Stripe redirects)
NEXT_PUBLIC_APP_URL=https://app.youthcoachhub.com

# Optional: Only needed if using Sentry for error monitoring
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# Stripe Configuration
# =============================================================================
# Get these from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Webhook Secret - Get from: Stripe Dashboard → Developers → Webhooks → Your endpoint → Signing secret
# Webhook URL should be: https://your-app.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# =============================================================================
# Stripe Price IDs for Subscriptions
# Get these from: Stripe Dashboard → Products → Your Product → Pricing
# Each product needs TWO prices: monthly recurring and yearly recurring
# =============================================================================

# Plus Tier ($29/month, $290/year)
STRIPE_PRICE_PLUS_MONTHLY=price_xxxxx
STRIPE_PRICE_PLUS_YEARLY=price_xxxxx

# Premium Tier ($79/month, $790/year)
STRIPE_PRICE_PREMIUM_MONTHLY=price_xxxxx
STRIPE_PRICE_PREMIUM_YEARLY=price_xxxxx

# AI Powered Tier ($199/month, $1990/year)
STRIPE_PRICE_AI_POWERED_MONTHLY=price_xxxxx
STRIPE_PRICE_AI_POWERED_YEARLY=price_xxxxx

# =============================================================================
# Stripe Price IDs for One-Time Purchases (Extra Video Minutes)
# These are one-time payments, not recurring subscriptions
# =============================================================================

# 15 Extra Minutes ($15)
STRIPE_PRICE_MINUTES_15=price_xxxxx

# 30 Extra Minutes ($25)
STRIPE_PRICE_MINUTES_30=price_xxxxx

# 60 Extra Minutes ($45)
STRIPE_PRICE_MINUTES_60=price_xxxxx

# 120 Extra Minutes ($79)
STRIPE_PRICE_MINUTES_120=price_xxxxx

# Test Hub — base email for creating test accounts
# Format: localpart@domain.com — accounts get +type-shortid inserted
# Example: myapp@gmail.com → myapp+coach-x4k9m2@gmail.com
TEST_ACCOUNT_EMAIL_BASE=your_email@gmail.com
